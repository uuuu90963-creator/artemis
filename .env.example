# ============================================================
# Artemis Agent 环境变量配置
# 复制此文件为 .env 并填入真实密钥
# ============================================================

# --------------- LLM Provider（至少选一个）---------------

# MiniMax API（主要文本模型，推荐）
# 获取地址: https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# OpenRouter API（支持 vision + tool calling，自动 fallback）
# 获取地址: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# DeepSeek API（可选）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Anthropic API（可选，Claude 系列）
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API（可选）
# 获取地址: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --------------- Telegram Bot ---------------

# Telegram Bot Token（可选，不填则不启用 Telegram 功能）
# 通过 @BotFather 获取: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 允许使用 Bot 的用户 ID（留空则允许所有人）
# 多个 ID 用逗号分隔，例如: 123456789,987654321
ALLOWED_USER_IDS=

# --------------- Vision / 图片分析 ---------------

# Ollama Vision（本地，免费）
# 启动命令: ollama run llava
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava

# OpenRouter Vision（使用上面的 OPENROUTER_API_KEY，无需额外配置）

# --------------- 路径配置（通常不需要修改）---------------

# Artemis 根目录
# ARTEMIS_HOME=/root/.hermes/artemis

# OpenClaw 工作区（Artemis 会自动发现，无需配置）
# WORKSPACE_DIR=/root/.hermes

# --------------- 日志 ---------------

# 日志级别: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO
